	    printf (" executar soma\n");
	    soma (1,2);
	}
	  else if (escolha ==2){
	      printf (" executar multiplicacao\n");
	      multiplicacao (3,4);
	  }  
	  else if (escolha ==3){
	      printf ("executar subtracao\n");
	      subtracao(8,2);
	      
	  }
	  else if (escolha ==4){
